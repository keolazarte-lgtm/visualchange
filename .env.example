# MagicVisual — Variables de entorno
# Copiá este archivo a .env y completá los valores
# Para deploy en Railway/Render/Vercel, configurá estas vars en el dashboard

# ===== OBLIGATORIO =====
# Tu API key de Z.ai — obtenela gratis en:
# https://z.ai/manage-apikey/apikey-list
ZAI_API_KEY=tu_api_key_aqui

# ===== OPCIONALES (con defaults) =====

# Puerto (las plataformas lo inyectan automáticamente, no hace falta tocarlo)
# PORT=3000

# Rate limit: 0 = ilimitado (default para uso personal)
# Si lo vas a compartir públicamente, seteá 10 para evitar abuso
RATE_LIMIT_MAX=0

# ===== NOTAS =====
# - HuggingFace InsightFace NO requiere API key (es espacio público)
# - sharp (procesamiento de imágenes) no requiere config
# - El server se reinicia solo si crashea (auto-restart en código)
